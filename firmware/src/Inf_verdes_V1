void cargarCredenciales() {
  prefs.begin("wifi", true);
  wifi_ssid = prefs.getString("ssid", "");
  wifi_pass = prefs.getString("pass", "");
  prefs.end();
}

void guardarCredenciales(const String& ssid, const String& pass) {
  prefs.begin("wifi", false);
  prefs.putString("ssid", ssid);
  prefs.putString("pass", pass);
  prefs.end();
}

bool conectarSTA_ConTimeout(unsigned long timeoutMs) {
  if (wifi_ssid.length() == 0) return false;

  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);

  if (wifi_pass.length() == 0) {
    Serial.println("[WIFI] Intentando red abierta...");
    WiFi.begin(wifi_ssid.c_str());
  } else {
    WiFi.begin(wifi_ssid.c_str(), wifi_pass.c_str());
  }

  Serial.printf("[WIFI] Conectando a '%s' ...\n", wifi_ssid.c_str());

  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED && (millis() - start) < timeoutMs) {
    delay(200);
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("[WIFI] OK IP: ");
    Serial.println(WiFi.localIP());
    return true;
  }

  Serial.println("[WIFI] No conectado.");
  return false;
}

void iniciarAP() {
  WiFi.mode(WIFI_AP);
  WiFi.softAP("TechosVerdes-Setup", "12345678");
  Serial.print("[AP] IP: ");
  Serial.println(WiFi.softAPIP());
}

