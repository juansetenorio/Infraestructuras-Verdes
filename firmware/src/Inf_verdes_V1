// ===================== ROUTES =====================
void routesConfigMode() {
  server.on("/", HTTP_GET, [](){ server.send(200, "text/html", configPageHTML()); });

  server.on("/save", HTTP_POST, [](){
    String ssid = server.arg("ssid");
    String pass = server.arg("pass"); // opcional
    if (ssid.length() < 1) { server.send(400, "text/html", configPageHTML("SSID inválido")); return; }
    guardarCredenciales(ssid, pass);
    server.send(200, "text/html", configPageHTML("Guardado, reiniciando..."));
    delay(800);
    ESP.restart();
  });

  server.onNotFound([](){ server.send(404, "text/plain", "Not found"); });
}

void routesDashboardMode() {
  server.on("/", HTTP_GET, [](){ server.send(200, "text/html", dashboardHTML()); });
  server.on("/api", HTTP_GET, [](){ server.send(200, "application/json", apiJSON()); });

  server.on("/valve", HTTP_POST, []() {
    String s = server.arg("set");
    if (s == "1") setValvula(true);
    else if (s == "0") setValvula(false);
    server.send(200, "application/json", "{\"ok\":true}");
  });

  server.onNotFound([](){ server.send(404, "text/plain", "Not found"); });
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);
  delay(400);
  Serial.println("\n== Techos Verdes robusto ==");

  pinMode(VALVE_PIN, OUTPUT);
  digitalWrite(VALVE_PIN, LOW);

  pinMode(FLOW_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_PIN), contarPulsos, RISING);

  pinMode(MAX485_DE, OUTPUT);
  digitalWrite(MAX485_DE, LOW);

  RS485Serial.begin(9600, SERIAL_8N1, RX2_PIN, TX2_PIN);
  node.begin(1, RS485Serial);
  node.preTransmission(preTransmission);
  node.postTransmission(postTransmission);

  ds18b20.begin();

  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(100000);
  Wire.setTimeOut(30);

  i2cBusRecovery();
  scanI2C();
  tryInitSHT31();

  cargarCredenciales();
  bool conectado = conectarSTA_ConTimeout(15000);

  if (conectado) {
    routesDashboardMode();
    server.begin();
    Serial.print("[WEB] Dashboard en http://");
    Serial.println(WiFi.localIP());
  } else {
    iniciarAP();
    routesConfigMode();
    server.begin();
    Serial.println("[WEB] Config en http://192.168.4.1");
  }

  Serial.println("Comandos: '1' abrir | '0' cerrar | 'i' scan I2C");
}

// ===================== LOOP =====================
void loop() {
  server.handleClient();

  if (Serial.available()) {
    char c = Serial.read();
    if (c == '1') setValvula(true);
    else if (c == '0') setValvula(false);
    else if (c == 'i') { scanI2C(); tryInitSHT31(); }
  }

  unsigned long now = millis();

  if (now - lastI2cScanTime >= i2cScanInterval) {
    scanI2C();
    lastI2cScanTime = now;
  }

  // reintento init SHT periódico si fallan
  if (now - lastShtInitTry >= shtReinitEveryMs) {
    if (!sht31_low_ok || !sht31_high_ok) {
      i2cBusRecovery();
      scanI2C();
      tryInitSHT31();
    }
    lastShtInitTry = now;
  }

  if (now - lastReadTime >= readInterval) {
    leerModbus();
    leerDS18B20();
    leerSHT31Seguro();
    calcularFlujo();

    Serial.printf("[DATA] I2C[%s] 44=%d 45=%d | low=%.2f/%.2f high=%.2f/%.2f\n",
      i2cDevices.c_str(),
      sht31_low_ok ? 1 : 0, sht31_high_ok ? 1 : 0,
      air_temp_low, air_humidity_low, air_temp_high, air_humidity_high
    );

    lastReadTime = now;
  }

  if (now - lastSendTime >= sendInterval) {
    enviarOrionSiConectado();
    lastSendTime = now;
  }
}
