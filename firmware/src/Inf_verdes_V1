// ===================== FLUJO (INTERRUPT) =====================
volatile uint32_t pulsosFlujo = 0;
portMUX_TYPE mux = portMUX_INITIALIZER_UNLOCKED;

void IRAM_ATTR contarPulsos() {
  portENTER_CRITICAL_ISR(&mux);
  pulsosFlujo++;
  portEXIT_CRITICAL_ISR(&mux);
}

// ===================== RS485 =====================
void preTransmission()  { digitalWrite(MAX485_DE, HIGH); delay(2); }
void postTransmission() { delay(2); digitalWrite(MAX485_DE, LOW);  }

// ===================== UTIL =====================
void setValvula(bool abrir) {
  valve_state = abrir;
  digitalWrite(VALVE_PIN, abrir ? HIGH : LOW);

  if (abrir) {
    portENTER_CRITICAL(&mux);
    pulsosFlujo = 0;
    portEXIT_CRITICAL(&mux);
    flow_litros_sesion = 0.0f;
    Serial.println("[VALVULA] ABIERTA");
  } else {
    Serial.printf("[VALVULA] CERRADA - Sesion: %.3f L\n", flow_litros_sesion);
  }
}

// Recuperación de bus I2C por software (útil cuando queda “colgado”)
void i2cBusRecovery() {
  pinMode(I2C_SDA, INPUT_PULLUP);
  pinMode(I2C_SCL, INPUT_PULLUP);
  delay(2);

  // Si SDA está en LOW, generar clocks para liberar esclavo
  if (digitalRead(I2C_SDA) == LOW) {
    pinMode(I2C_SCL, OUTPUT_OPEN_DRAIN);
    for (int i = 0; i < 20; i++) {
      digitalWrite(I2C_SCL, HIGH); delayMicroseconds(8);
      digitalWrite(I2C_SCL, LOW);  delayMicroseconds(8);
    }
    pinMode(I2C_SDA, OUTPUT_OPEN_DRAIN);
    // STOP condition
    digitalWrite(I2C_SDA, LOW); delayMicroseconds(8);
    digitalWrite(I2C_SCL, HIGH); delayMicroseconds(8);
    digitalWrite(I2C_SDA, HIGH); delayMicroseconds(8);
  }

  // Re-init Wire
  Wire.end();
  delay(2);
  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(100000); // más estable con cableado real
  Wire.setTimeOut(30);   // evita bloqueos largos
}

void scanI2C() {
  i2cCount = 0;
  addr44_found = false;
  addr45_found = false;
  i2cDevices = "";

  for (uint8_t addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    uint8_t err = Wire.endTransmission();
    if (err == 0) {
      i2cCount++;
      char b[8];
      snprintf(b, sizeof(b), "0x%02X", addr);
      if (i2cDevices.length()) i2cDevices += ", ";
      i2cDevices += b;
      if (addr == 0x44) addr44_found = true;
      if (addr == 0x45) addr45_found = true;
    }
  }

  Serial.printf("[I2C] count=%u devices=[%s]\n", i2cCount, i2cDevices.c_str());
}

void tryInitSHT31() {
  // Solo intenta re-inicializar los que falten
  if (!sht31_low_ok && addr44_found) {
    sht31_low_ok = sht31_low.begin(SHT31_ADDR_LOW);
    Serial.printf("[SHT31] Init 0x44 => %s\n", sht31_low_ok ? "OK" : "FAIL");
  }
  if (!sht31_high_ok && addr45_found) {
    sht31_high_ok = sht31_high.begin(SHT31_ADDR_HIGH);
    Serial.printf("[SHT31] Init 0x45 => %s\n", sht31_high_ok ? "OK" : "FAIL");
  }
}

// ===================== SENSORES =====================
void leerModbus() {
  uint8_t res = node.readHoldingRegisters(2, 2);
  if (res == node.ku8MBSuccess) {
    soil_humidity_1 = node.getResponseBuffer(0) / 10.0f;
    soil_temp_1     = node.getResponseBuffer(1) / 10.0f;
    modbus_ok = true;
  } else {
    modbus_ok = false;
    Serial.printf("[MODBUS] Error: 0x%02X\n", res);
  }
}

void leerDS18B20() {
  ds18b20.requestTemperatures();
  float t = ds18b20.getTempCByIndex(0);
  if (t == DEVICE_DISCONNECTED_C) {
    soil_temp_2 = 0.0f;
    ds18b20_ok = false;
  } else {
    soil_temp_2 = t;
    ds18b20_ok = true;
  }
}

void leerSHT31Seguro() {
  // Si no están detectados, no leer
  if (sht31_low_ok) {
    float t1 = sht31_low.readTemperature();
    float h1 = sht31_low.readHumidity();
    if (!isnan(t1) && !isnan(h1)) {
      air_temp_low = t1;
      air_humidity_low = h1;
    } else {
      sht31_low_ok = false; // marcar para reinicializar luego
      Serial.println("[SHT31] Lectura invalida 0x44");
    }
  } else {
    air_temp_low = 0.0f;
    air_humidity_low = 0.0f;
  }

  if (sht31_high_ok) {
    float t2 = sht31_high.readTemperature();
    float h2 = sht31_high.readHumidity();
    if (!isnan(t2) && !isnan(h2)) {
      air_temp_high = t2;
      air_humidity_high = h2;
    } else {
      sht31_high_ok = false;
      Serial.println("[SHT31] Lectura invalida 0x45");
    }
  } else {
    air_temp_high = 0.0f;
    air_humidity_high = 0.0f;
  }
}

void calcularFlujo() {
  if (!valve_state) return;

  uint32_t pulsos = 0;
  portENTER_CRITICAL(&mux);
  pulsos = pulsosFlujo;
  pulsosFlujo = 0;
  portEXIT_CRITICAL(&mux);

  float litros = pulsos / PULSOS_POR_LITRO;
  flow_litros_sesion += litros;
  flow_litros_total  += litros;
}

// ===================== ORION =====================
String construirPayloadOrion() {
  StaticJsonDocument<1792> doc;

  doc["soil_temp_1"]["type"] = "Number";        doc["soil_temp_1"]["value"] = soil_temp_1;
  doc["soil_humidity_1"]["type"] = "Number";    doc["soil_humidity_1"]["value"] = soil_humidity_1;
  doc["soil_temp_2"]["type"] = "Number";        doc["soil_temp_2"]["value"] = soil_temp_2;

  doc["air_temp_low"]["type"] = "Number";       doc["air_temp_low"]["value"] = air_temp_low;
  doc["air_humidity_low"]["type"] = "Number";   doc["air_humidity_low"]["value"] = air_humidity_low;
  doc["air_temp_high"]["type"] = "Number";      doc["air_temp_high"]["value"] = air_temp_high;
  doc["air_humidity_high"]["type"] = "Number";  doc["air_humidity_high"]["value"] = air_humidity_high;

  doc["flow_litros_sesion"]["type"] = "Number"; doc["flow_litros_sesion"]["value"] = flow_litros_sesion;
  doc["flow_litros_total"]["type"] = "Number";  doc["flow_litros_total"]["value"] = flow_litros_total;
  doc["valve_state"]["type"] = "Number";        doc["valve_state"]["value"] = valve_state ? 1 : 0;

  String payload;
  serializeJson(doc, payload);
  return payload;
}

void enviarOrionSiConectado() {
  if (!ORION_HABILITADO) return;
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.begin(serverUrl);
  http.addHeader("Content-Type", "application/json");

  String payload = construirPayloadOrion();
  int httpCode = http.POST(payload);
  Serial.printf("[ORION] HTTP: %d\n", httpCode);
  if (httpCode != 204) Serial.println(http.getString());

  http.end();
}

